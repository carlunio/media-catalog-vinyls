[Desktop Entry]
Version=1.0
Type=Application
Name=Media Catalog Vinyls - Stop
Comment=Stop backend and frontend
Terminal=true
Icon=utilities-terminal
Categories=Development;
Exec=sh -c 'desktop_file="$1"; desktop_file="${desktop_file#file://}"; script_dir="$(CDPATH= cd -- "$(dirname -- "$desktop_file")" && pwd)"; exec "$script_dir/stop-app.sh"' sh %k
