[Desktop Entry]
Version=1.0
Type=Application
Name=Media Catalog Vinyls - Setup
Comment=Create venv and install dependencies
Terminal=true
Icon=utilities-terminal
Categories=Development;
Exec=sh -c 'desktop_file="$1"; desktop_file="${desktop_file#file://}"; script_dir="$(CDPATH= cd -- "$(dirname -- "$desktop_file")" && pwd)"; exec "$script_dir/set-up-app.sh"' sh %k
